<Window x:Class="IT2A_database.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:IT2A_database"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <DataGrid x:Name="dgFilmy"
      Grid.Column="0"
      Margin="0,0,323,0"
      AutoGenerateColumns="False"
      CanUserAddRows="False"
      IsReadOnly="True"
      SelectionMode="Single"
      SelectionUnit="FullRow" SelectionChanged="dgFilmy_SelectionChanged" ItemsSource="{Binding Movies}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Název" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Žánr" Binding="{Binding Genre}" Width="*"/>
                <DataGridTextColumn Header="Délka (min)" Binding="{Binding Length}" Width="100"/>
                <DataGridTextColumn Header="Hodnocení (%)" Binding="{Binding Rating}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <Label Content="Evidence filmů" HorizontalAlignment="Left" Margin="488,10,0,0" VerticalAlignment="Top" FontSize="24"/>

        <TextBlock Margin="488,55,0,0" VerticalAlignment="Top">
        <Run Text="Název:" />
        </TextBlock>
        <TextBox Margin="488,76,18,334" Width="294" x:Name="tbName"/>

        <TextBlock Margin="488,108,0,0" VerticalAlignment="Top">
        <Run Text="Žánr:"/>
        </TextBlock>
        <TextBox Margin="488,138,18,281" Width="294" x:Name="tbGenre"/>

        <TextBlock Margin="488,164,0,0" VerticalAlignment="Top">
        <Run Text="Délka:"/>
        </TextBlock>
        <TextBox Margin="488,184,18,234" Width="294" x:Name="tbLength"/>

        <TextBlock Margin="488,200,0,0" VerticalAlignment="Top">
        <Run Text="Hodnocení (%)"/>
        </TextBlock>
        <TextBox Margin="488,221,18,188" Width="294" x:Name="tbRating"/>

        <Button Content="Přidat film" Height="30" Margin="496,327,10,77" Width="294" Click="Add_Click"/>
        <Button Content="Načíst vybraný film" Margin="496,255,10,152" Width="294" Click="Load_Click"/>
        <Button Content="Upravit film" Margin="497,292,9,116" Width="294" Click="Update_Click"/>
        <Button Content="Smazat film" Margin="496,370,10,38" Width="294" Click="Delete_Click"/>
    </Grid>

</Window>
