<Window x:Class="IT2A_database.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:IT2A_database"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition Width="250"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <DataGrid x:Name="dgKnihy"
          FontSize="20"
  Grid.Column="0"
  AutoGenerateColumns="False"
  CanUserAddRows="False"
  IsReadOnly="True"
  SelectionMode="Single"
  ColumnHeaderHeight="60"
  SelectionUnit="FullRow">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Film" Binding="{Binding Nazev}" Width="*"/>
                <DataGridTextColumn Header="Režie" Binding="{Binding Autor}" Width="*"/>
                <DataGridTextColumn Header="Cena" Binding="{Binding RokVydani}" Width="80"/>
                <DataGridTextColumn Header="Dostupné" Binding="{Binding Zanr}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
        <TextBlock Grid.Column="1" FontSize="30">Evidence filmlů</TextBlock>
        <TextBlock Grid.Column="1" FontSize="20" Margin="10, 40, 0, 0">Film:</TextBlock>
        <TextBox Grid.Column="1" Height="30" BorderBrush="Black" Margin="10, -260, 20, 0" BorderThickness="1"></TextBox>
        <TextBlock Grid.Column="1" FontSize="20" Margin="10, 110, 0, 0">Režie:</TextBlock>
        <TextBox Grid.Column="1" Height="30" BorderBrush="Black" Margin="10, -120, 20, 0" BorderThickness="1"></TextBox>
        <TextBlock Grid.Column="1" FontSize="20" Margin="10, 180, 0, 0">Cena:</TextBlock>
        <TextBox Grid.Column="1" Height="30" BorderBrush="Black" Margin="10, 20, 20, 0" BorderThickness="1"></TextBox>
        <CheckBox Grid.Column="1" Margin="20, 250, 0, 0" BorderBrush="Black" BorderThickness="1">Skladem</CheckBox>
        <Button Grid.Column="1" Height="25" Margin="20, 140, 20, 0">Přidat film</Button>
        <Button Grid.Column="1" Height="25" Margin="20, 200, 20, 0">Načíst vybrané do furmuláře</Button>
        <Button Grid.Column="1" Height="25" Margin="20, 260, 20, 0">Upravit vybrané filmy</Button>
        <Button Grid.Column="1" Height="25" Margin="20, 320, 20, 0">Smazat vybrané filmy</Button>
        <Button Grid.Column="1" Height="25" Margin="20, 380, 20, 0">Smazat všechno</Button>
    </Grid>

</Window>
